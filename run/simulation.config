#
# This file defines all the configuration options for WPS+WRF-Chem runs.
#
# In order to be "universally" parsable, this file should only be written as a
# series of "my_variable=my_value" lines.
#
# This file should be self-documented.
#
# This file is meant to be sourced rather than executed, because it defines
# local environment variables.

# Directory where WPS is installed
wps_installed=~/WPS

# Directory where WRF is installed
wrf_installed=~/WRF

# Name that is descriptive of the simulation. Users can choose what they want
case_name="wrf-chem-test"

# Start and end dates of the simulation. The format is anything accepted by the
# shell "date" function, for example "1789-07-14", or "1789-07-14 15:50"
date_start=2015-02-15
date_end=2015-02-16
